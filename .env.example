# Variables d'environnement pour le déploiement
# Copier ce fichier vers .env.local pour le développement local

# Limite de taille des fichiers audio (en MB)
BEATSYNC_MAX_AUDIO_MB=30
# Valeurs sûres pour Render (évite les 502 sur gros multipart)
BEATSYNC_MAX_VIDEO_MB=95
BEATSYNC_MAX_TOTAL_VIDEO_MB=180

# Local uniquement. Sur Render, ne PAS définir PORT manuellement.
PORT=3000

# Pour le déploiement en production, ajouter :
# NODE_ENV=production