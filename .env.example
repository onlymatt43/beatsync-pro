# Variables d'environnement pour le déploiement
# Copier ce fichier vers .env.local pour le développement local

# Limite de taille des fichiers audio (en MB)
BEATSYNC_MAX_AUDIO_MB=30

# Limite de taille d'une vidéo individuelle (en MB)
BEATSYNC_MAX_VIDEO_MB=250

# Limite cumulée de toutes les vidéos envoyées dans une analyse (en MB)
BEATSYNC_MAX_TOTAL_VIDEO_MB=800

# Port pour le développement (par défaut 3000)
PORT=3000

# Pour le déploiement en production, ajouter :
# NODE_ENV=production